#### Email Parsing Engine — Strategy Pattern

Each email type has a dedicated parsing rule that implements `IEmailParsingRule`:

```csharp
public interface IEmailParsingRule
{
    bool CanParse(string senderEmail, string subject, string body);
    ParsedTransactionDto? Parse(string senderEmail, string subject, string body, DateTime emailDate);
    float ConfidenceScore { get; }
}
```

**Example: Swiggy Parsing Rule**
```csharp
public class SwiggyParsingRule : IEmailParsingRule
{
    public float ConfidenceScore => 0.95f;

    public bool CanParse(string senderEmail, string subject, string body)
    {
        return senderEmail.Contains("swiggy.in") &&
               (subject.Contains("Order Delivered") || subject.Contains("Payment Receipt"));
    }

    public ParsedTransactionDto? Parse(string senderEmail, string subject, string body, DateTime emailDate)
    {
        // Regex patterns to extract amount, order ID, etc.
        var amountMatch = Regex.Match(body, @"(?:₹|Rs\.?|INR)\s*([\d,]+\.?\d*)");
        if (!amountMatch.Success) return null;

        return new ParsedTransactionDto
        {
            Amount = decimal.Parse(amountMatch.Groups[1].Value.Replace(",", "")),
            Category = "Food & Dining",
            TransactionType = "Expense",
            Description = $"Swiggy Order - {subject}",
            MerchantName = "Swiggy",
            TransactionDate = emailDate
        };
    }
}
```

